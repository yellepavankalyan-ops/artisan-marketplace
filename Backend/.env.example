PORT=5000

# MongoDB Atlas connection string (standard format avoids +srv DNS issues)
DB_URL=mongodb://localhost:27017/artisan

# Long random string used to sign JWTs - generate with: openssl rand -base64 32
SECRET_KEY=

# Set to "production" when deployed (enables secure/cross-site cookies)
NODE_ENV=development

# Cloudinary (Dashboard -> copy these three values)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay (Dashboard -> Settings -> API Keys)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=

# Comma-separated list of extra allowed frontend origins (custom domains),
# e.g. https://your-app.vercel.app,https://www.yourdomain.com
FRONTEND_URL=
